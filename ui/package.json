{
    "name": "kestra",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "packageManager": "npm@10.9.0",
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "dev": "vite --host",
        "build": "vite build --emptyOutDir",
        "build:design": "npm run build --workspace=@kestra-io/design-system",
        "build:topology": "npm run build --workspace=@kestra-io/topology",
        "preview": "vite preview",
        "check:types": "vue-tsc --noEmit",
        "test:lint": "eslint",
        "test:all": "vitest run --coverage",
        "test:unit": "vitest run --project=unit",
        "test:storybook": "vitest run --project=storybook",
        "test:e2e": "./run-e2e-tests.sh",
        "test:e2e-without-starting-backend": "playwright test --config=tests/e2e/playwright.config.ts",
        "translations:check": "node ./src/translations/check.js",
        "lint": "eslint --fix",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build",
        "prepare": "cd .. && husky ui/.husky && rimraf .git/hooks || true",
        "postinstall": "patch-package"
    },
    "dependencies": {
        "@js-joda/core": "^6.0.1",
        "@kestra-io/design-system": "*",
        "@kestra-io/topology": "*",
        "@kestra-io/ui-libs": "^0.0.302",
        "@vue-flow/background": "^1.3.2",
        "@vue-flow/controls": "^1.1.3",
        "@vue-flow/core": "^1.48.2",
        "@vueuse/core": "^14.3.0",
        "ansi-to-html": "^0.7.2",
        "axios": "1.16.0",
        "bootstrap": "^5.3.8",
        "buffer": "^6.0.3",
        "cronstrue": "^3.14.0",
        "dagre": "^0.8.5",
        "dotenv": "^17.4.2",
        "echarts": "^6.0.0",
        "lodash": "^4.18.1",
        "mailchecker": "^6.0.20",
        "material-file-icons": "^2.4.0",
        "md5": "^2.3.0",
        "moment": "^2.30.1",
        "moment-range": "^4.0.2",
        "moment-timezone": "^0.6.2",
        "nprogress": "^0.2.0",
        "path-browserify": "^1.0.1",
        "pdfjs-dist": "^5.7.284",
        "pinia": "^3.0.4",
        "posthog-js": "^1.372.9",
        "rapidoc": "^9.3.8",
        "remark-directive": "^4.0.0",
        "remark-frontmatter": "^5.0.0",
        "semver": "^7.7.4",
        "vue": "^3.5.34",
        "vue-echarts": "^8.0.1",
        "vue-gtag": "^3.7.1",
        "vue-i18n": "^11.4.2",
        "vue-material-design-icons": "^5.3.1",
        "vue-router": "^5.0.6",
        "vue-sidebar-menu": "^5.9.1",
        "vue-virtual-scroller": "^3.0.3",
        "xss": "^1.0.15",
        "yaml": "^2.8.3"
    },
    "devDependencies": {
        "@codecov/vite-plugin": "^2.0.1",
        "@esbuild-plugins/node-modules-polyfill": "^0.2.2",
        "@eslint/js": "^9.39.4",
        "@playwright/test": "^1.59.1",
        "@rushstack/eslint-patch": "^1.16.1",
        "@storybook/addon-themes": "^10.3.3",
        "@storybook/addon-vitest": "^10.3.3",
        "@storybook/vue3-vite": "^10.3.3",
        "@types/bootstrap": "^5.2.10",
        "@types/humanize-duration": "^3.27.4",
        "@types/js-yaml": "^4.0.9",
        "@types/moment": "^2.13.0",
        "@types/node": "^25.6.0",
        "@types/nprogress": "^0.2.3",
        "@types/path-browserify": "^1.0.3",
        "@types/semver": "^7.7.1",
        "@types/testing-library__jest-dom": "^6.0.0",
        "@types/testing-library__user-event": "^4.2.0",
        "@typescript-eslint/parser": "^8.59.2",
        "@vitejs/plugin-vue": "^6.0.6",
        "@vitejs/plugin-vue-jsx": "^5.1.5",
        "@vitest/browser": "^4.1.5",
        "@vitest/browser-playwright": "^4.1.5",
        "@vitest/coverage-v8": "^4.1.5",
        "@vue/eslint-config-prettier": "^10.2.0",
        "@vue/test-utils": "^2.4.10",
        "@vueuse/router": "^14.3.0",
        "change-case": "5.4.4",
        "cross-env": "^10.1.0",
        "eslint": "^9.39.4",
        "eslint-plugin-storybook": "^10.3.3",
        "eslint-plugin-vue": "^9.33.0",
        "globals": "^17.6.0",
        "husky": "^9.1.7",
        "jsdom": "^29.1.1",
        "lint-staged": "^16.4.0",
        "monaco-editor": "^0.52.2",
        "monaco-yaml": "5.3.1",
        "patch-package": "^8.0.1",
        "playwright": "^1.59.1",
        "prettier": "^3.8.3",
        "rimraf": "^6.1.3",
        "rollup-plugin-copy": "^3.5.0",
        "sass": "^1.99.0",
        "storybook": "^10.3.3",
        "storybook-vue3-router": "^7.0.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.59.2",
        "uuid": "^14.0.0",
        "vite": "^8.0.11",
        "vitest": "^4.1.5",
        "vue-tsc": "^3.2.8"
    },
    "optionalDependencies": {
        "@esbuild/darwin-arm64": "^0.28.0",
        "@esbuild/darwin-x64": "^0.28.0",
        "@esbuild/linux-x64": "^0.28.0",
        "@rolldown/binding-darwin-arm64": "^1.0.0-rc.16",
        "@rolldown/binding-darwin-x64": "^1.0.0-rc.16",
        "@rolldown/binding-linux-x64-gnu": "^1.0.0-rc.16",
        "@rollup/rollup-darwin-arm64": "^4.60.3",
        "@rollup/rollup-darwin-x64": "^4.60.3",
        "@rollup/rollup-linux-x64-gnu": "^4.60.3",
        "@swc/core-darwin-arm64": "^1.15.32",
        "@swc/core-darwin-x64": "^1.15.32",
        "@swc/core-linux-x64-gnu": "^1.15.32",
        "lightningcss-darwin-arm64": "^1.32.0",
        "lightningcss-darwin-x64": "^1.32.0",
        "lightningcss-linux-x64-gnu": "^1.32.0"
    },
    "overrides": {
        "axios": "1.16.0",
        "@popperjs/core": "npm:@sxzz/popperjs-es@^2.11.7",
        "@codecov/vite-plugin": {
            "vite": "$vite"
        }
    },
    "lint-staged": {
        "**/*.{js,mjs,cjs,ts,vue}": "eslint --fix"
    }
}